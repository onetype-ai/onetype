        ".": "./index.js",
        "./workspace/teams": "./addons/workspace/teams/back/load.js",
        "./workspace/users": "./addons/workspace/users/back/load.js",
        "./workspace/projects": "./addons/workspace/projects/back/load.js",
        "./workspace/tokens": "./addons/workspace/tokens/back/load.js"
    },
    "license": "MIT",
    "author": "Dejan Tomic <hi@iamdejan.com>",
